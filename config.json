{
  "runtime": {
    "DEVICE": "amd"
  },
  "handler": {
    "DATA_DIR": "",
    "_comment": "FILE_PATTERNS is deprecated. Use include_extensions, exclude_extensions, include_patterns, or exclude_patterns instead.",
    "FILE_PATTERNS": [
      ".*\\.txt$",
      ".*\\.log$",
      ".*\\.csv$",
      ".*\\.tsv$",
      ".*\\.md$",
      ".*\\.rst$",
      ".*\\.json$",
      ".*\\.yaml$",
      ".*\\.yml$",
      ".*\\.toml$",
      ".*\\.py$",
      ".*\\.js$",
      ".*\\.ts$",
      ".*\\.java$",
      ".*\\.cpp$",
      ".*\\.c$",
      ".*\\.go$",
      ".*\\.pdf$"
    ],
    "_comment2": "By default, reads ALL text-based files. Uncomment below to customize:",
    "_include_extensions": [".py", ".js", ".md", ".txt"],
    "_exclude_extensions": [".log", ".tmp"],
    "_include_patterns": [".*\\.py$", ".*src/.*"],
    "_exclude_patterns": [".*test.*", ".*__pycache__.*", ".*node_modules.*"]
  },
  "trainer": {
    "CHECKPOINT_FILE": "",
    "BLOCK_SIZE": 128,
    "BATCH_SIZE": 32,
    "LR": 0.0003,
    "EPOCHS": 5
  },
  "model": {
    "EMBED_DIM": 128,
    "N_HEAD": 4,
    "N_LAYER": 2
  }
}